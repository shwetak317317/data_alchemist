# ── LLM provider selection ────────────────────────────────────────────────────
# Set ONE provider. It auto-wires the model, key, and base URL.
# Leave blank to use llm_config.yaml directly (legacy mode).
#
#   LLM_PROVIDER=ollama      → self-hosted Ollama, no API key needed
#   LLM_PROVIDER=gemini      → Google AI Studio (GEMINI_API_KEY)
#   LLM_PROVIDER=anthropic   → Anthropic Claude  (ANTHROPIC_API_KEY)
#   LLM_PROVIDER=openai      → OpenAI            (OPENAI_API_KEY)
#   LLM_PROVIDER=azure       → Azure OpenAI      (AZURE_API_KEY + AZURE_API_BASE)
LLM_PROVIDER=ollama


# ── Ollama / LiteLLM proxy ────────────────────────────────────────────────────
# Calls are routed through a LiteLLM proxy server (default port 3300).
# Model name must match what is registered in the proxy UI.
OLLAMA_BASE_URL=http://10.10.64.25:3300
OLLAMA_MODEL=openai/qwen3.5:4b
OLLAMA_API_KEY=sk-SLdbmxiKzPcBnGoNBbC8nQ                         # virtual key from the LiteLLM proxy UI

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AQ.Ab8RN6JJgy4IHkuD-u3FT80nAf6clCODAmGJBbfzWaygVdDS-g           # https://aistudio.google.com/app/apikey
GEMINI_MODEL_NAME=gemini/gemini-2.0-flash # or gemini/gemini-2.5-flash-lite

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                        # sk-ant-...
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_API_KEY=
AZURE_API_BASE=                           # e.g. https://myresource.openai.azure.com
AZURE_API_VERSION=2024-02-01
AZURE_MODEL_NAME=azure/gpt-4o



# ── Metadata Store (PostgreSQL) ───────────────────────────────────────────────
# Used internally — populated automatically via docker-compose
DATABASE_URL=postgresql://datatrust:datatrust_pass@postgres:5432/datatrust_meta

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte secret for encrypting stored connection credentials
ENCRYPTION_KEY=change-me-32-chars-secret-key-here

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Microsoft Entra ID SSO (pal.tech) ────────────────────────────────────────
# See README.md → Microsoft SSO Setup for Azure App Registration steps
AZURE_TENANT_ID=                  # paste pal.tech tenant GUID here
AZURE_CLIENT_ID=                  # paste App Registration client ID here
AZURE_REDIRECT_URI=http://localhost
AZURE_DOMAIN_HINT=pal.tech

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development               # development | production
LOG_LEVEL=INFO
