# ── LLM ──────────────────────────────────────────────────────────────────────
# API key for whichever LLM provider you configure in llm_config.yaml
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=                   # leave blank if using Claude
AZURE_API_KEY=                    # Azure OpenAI key if using azure/gpt-4o
GEMINI_API_KEY=AQ.Ab8RN6KmEl7GinhVyfl6dr7HUzrO6kO9wMoLwcBqTbbn6DDocQ                    # Gemini API key if using Gemini
AZURE_API_BASE=                   # e.g. https://myresource.openai.azure.com
AZURE_API_VERSION=2024-02-01

# ── Metadata Store (PostgreSQL) ───────────────────────────────────────────────
# Used internally — populated automatically via docker-compose
DATABASE_URL=postgresql://datatrust:datatrust_pass@postgres:5432/datatrust_meta

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte secret for encrypting stored connection credentials
ENCRYPTION_KEY=change-me-32-chars-secret-key-here

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Microsoft Entra ID SSO (pal.tech) ────────────────────────────────────────
# See README.md → Microsoft SSO Setup for Azure App Registration steps
AZURE_TENANT_ID=                  # paste pal.tech tenant GUID here
AZURE_CLIENT_ID=                  # paste App Registration client ID here
AZURE_REDIRECT_URI=http://localhost
AZURE_DOMAIN_HINT=pal.tech

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development               # development | production
LOG_LEVEL=INFO
