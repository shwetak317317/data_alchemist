# ── LLM ──────────────────────────────────────────────────────────────────────
# API key for whichever LLM provider you configure in llm_config.yaml
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=                   # leave blank if using Claude
AZURE_API_KEY=                    # Azure OpenAI key if using azure/gpt-4o
AZURE_API_BASE=                   # e.g. https://myresource.openai.azure.com
AZURE_API_VERSION=2024-02-01

# ── Metadata Store (PostgreSQL) ───────────────────────────────────────────────
# Used internally — populated automatically via docker-compose
DATABASE_URL=postgresql://datatrust:datatrust_pass@localhost:5432/datatrust_meta

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte secret for encrypting stored connection credentials
ENCRYPTION_KEY=change-me-32-chars-secret-key-here

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Microsoft Entra ID SSO (pal.tech) ────────────────────────────────────────
# Register an App in Azure AD → App registrations → New registration
#   Supported account type: "Accounts in this organizational directory only (pal.tech)"
#   Redirect URI: Single-page application (SPA) → http://localhost
# Then copy the values below from the registered app's Overview page.
AZURE_TENANT_ID=                  # pal.tech tenant GUID (from Azure AD > Overview)
AZURE_CLIENT_ID=                  # App Registration client ID (from Overview)
AZURE_REDIRECT_URI=http://localhost
AZURE_DOMAIN_HINT=pal.tech        # pre-selects pal.tech in the Microsoft login picker

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development               # development | production
LOG_LEVEL=INFO
