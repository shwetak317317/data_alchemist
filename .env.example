# ── LLM provider selection ────────────────────────────────────────────────────
# Set LLM_PROVIDER to switch providers — all config lives here, no yaml needed.
#
#   LLM_PROVIDER=ollama      → LiteLLM proxy at OLLAMA_BASE_URL (openai/ prefix)
#   LLM_PROVIDER=gemini      → Google AI Studio direct (GEMINI_API_KEY)
#   LLM_PROVIDER=anthropic   → Anthropic Claude direct (ANTHROPIC_API_KEY)
#   LLM_PROVIDER=openai      → OpenAI direct (OPENAI_API_KEY)
#   LLM_PROVIDER=azure       → Azure OpenAI (AZURE_API_KEY + AZURE_API_BASE)
LLM_PROVIDER=ollama

# ── Ollama / LiteLLM proxy ────────────────────────────────────────────────────
# Calls are routed through a LiteLLM proxy server (default port 3300).
# Model name must match what is registered in the proxy UI.
OLLAMA_BASE_URL=http://10.10.64.25:3300
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_API_KEY=                           # virtual key from the LiteLLM proxy UI

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=                           # https://aistudio.google.com/app/apikey
GEMINI_MODEL_NAME=gemini/gemini-2.0-flash # or gemini/gemini-2.5-flash-lite

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                        # sk-ant-...
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_API_KEY=
AZURE_API_BASE=                           # e.g. https://myresource.openai.azure.com
AZURE_API_VERSION=2024-02-01
AZURE_MODEL_NAME=azure/gpt-4o

# ── Metadata Store (PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://datatrust:datatrust_pass@localhost:5432/datatrust_meta

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=change-me-32-chars-secret-key-here

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Microsoft Entra ID SSO (pal.tech) ────────────────────────────────────────
# Register an App in Azure AD → App registrations → New registration
#   Supported account type: "Accounts in this organizational directory only (pal.tech)"
#   Redirect URI: Single-page application (SPA) → http://localhost
# Then copy the values below from the registered app's Overview page.
AZURE_TENANT_ID=                  # pal.tech tenant GUID
AZURE_CLIENT_ID=                  # App Registration client ID
AZURE_REDIRECT_URI=http://localhost
AZURE_DOMAIN_HINT=pal.tech

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
